{
  "name": "api-growtwitter",
  "version": "1.0.0",
  "description": "API REST de um jogo desenvolvida com Node.js, Express e Prisma ORM para operações CRUD.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --setupFilesAfterEnv=./tests/setup.ts --detectOpenHandles",
    "test:watch": "cross-env NODE_ENV=test jest --watch --setupFilesAfterEnv=./tests/setup.ts",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand --setupFilesAfterEnv=./tests/setup.ts",
    "test:docker": "cross-env NODE_ENV=test npx prisma migrate deploy && npm run test",
    "test:integration": "cross-env NODE_ENV=test npx prisma migrate deploy && npm run test",
    "test:file": "cross-env NODE_ENV=test npx prisma migrate deploy && jest --runInBand --setupFilesAfterEnv=./tests/setup.ts --detectOpenHandles"
  },
  "keywords": [],
  "author": "Iara Tassi",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@types/uuid": "^8.3.4",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "glob": "^11.0.3",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.18.0",
    "supertest": "^7.1.4",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.0",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "jest": "^30.2.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
